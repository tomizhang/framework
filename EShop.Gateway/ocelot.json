{
  "Routes": [
    {
      // --- 路由规则 1: 转发商品查询 ---
      // 上游 (用户访问的地址): localhost:9000/eshop/products
      "UpstreamPathTemplate": "/eshop/{everything}",
      "UpstreamHttpMethod": [ "Get", "Post", "Put", "Delete" ],

      // 下游 (真实 API 的地址): localhost:5xxx/api/products
      "DownstreamPathTemplate": "/api/{everything}",
      "DownstreamScheme": "http",
      "ServiceName": "EShop-API-V2"

      // --- 🚦 限流配置 (Rate Limiting) ---
      //"RateLimitOptions": {
      //  "ClientWhitelist": [], // 白名单
      //  "EnableRateLimiting": true,
      //  "Period": "10s", // 统计周期：10秒内
      //  "Limit": 2, // 最大请求数：只能访问 2 次
      //  "PeriodTimespan": 10 // 触发限流后，封禁多少秒
      //}
    }
  ],
  "GlobalConfiguration": {
    "BaseUrl": "http://localhost:9000",
    "ServiceDiscoveryProvider": {
      "Host": "localhost",
      "Port": 8500,
      "Type": "Consul"
    }
  }
}