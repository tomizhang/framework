{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning", // 过滤掉微软内部的大量废话日志
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }, // 输出到控制台
      {
        "Name": "File", // 输出到文件
        "Args": {
          "path": "Logs/log-.txt", // 文件名格式 log-20231205.txt
          "rollingInterval": "Day", // 每天生成一个新文件
          "formatter": "Serilog.Formatting.Json.JsonFormatter, Serilog" // 存成 JSON 格式
        }
      }
    ]
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    // 请替换为你自己的 PostgreSQL 账号密码
    // Host=localhost;Database=EShopDb;Username=你的用户名;Password=你的密码
    "DefaultConnection": "Host=localhost;Database=eshopdb;Username=postgres;Password=password",
    "Redis": "localhost:6379" // 👈 新增这一行
  },
  "Jwt": {
    "Key": "MySuperSecretKey_MustBeLongerThan16Chars",
    "Issuer": "EShopAPI",
    "Audience": "EShopClient"
  },
  // 👇 新增这个配置块
  "WeChat": {
    "AppId": "wx1234567890abcdef", // 假设这是微信给我们的身份证
    "AppSecret": "super_secret_password_do_not_leak" // 假设这是私钥
  },
  "urls": "http://*:7001"
}